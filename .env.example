# Standalone / docker run config (ignored when installed as HA addon).
# Copy to .env and fill values:  cp .env.example .env

RTSP_URL=rtsp://192.168.5.3:8554/camera
MQTT_HOST=192.168.5.3
MQTT_PORT=1883
MQTT_USERNAME=razor
MQTT_PASSWORD=changeme
MQTT_TOPIC=hand_gesture_status
MQTT_ENABLE_TOPIC=hand_gesture_enable
RESET_HAND_STATUS_TIME=10
NUM_HANDS=4

# Detection sensitivity. Lower = more sensitive (more false positives).
MIN_HAND_DETECTION_CONFIDENCE=0.3
MIN_HAND_PRESENCE_CONFIDENCE=0.5
MIN_TRACKING_CONFIDENCE=0.5
MIN_GESTURE_SCORE=0.5

# Region-of-interest crop (fractions of frame, 0..1). Default = full frame.
# Example: hand only in bottom half -> ROI_TOP=0.5
ROI_TOP=0.0
ROI_BOTTOM=1.0
ROI_LEFT=0.0
ROI_RIGHT=1.0
